# ─────────────────────────────────────────────────────────────────────────────
# iHIMS API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/pibs"

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS — comma-separated allowed origins ────────────────────────────────────
CORS_ORIGIN="http://localhost:5173,http://localhost:5174,http://localhost:5175"

# ── App URL (used for PayMongo redirect URLs) ─────────────────────────────────
APP_URL="http://localhost:5175"

# ── PayMongo (Online Payments) ────────────────────────────────────────────────
# Leave blank to use simulation mode (no real charges)
# Get keys at: https://dashboard.paymongo.com/developers
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=

# ── Semaphore SMS ─────────────────────────────────────────────────────────────
# Leave blank to use simulation mode (logs to console, no real SMS sent)
# Get API key at: https://semaphore.co
SEMAPHORE_API_KEY=

# ── PhilHealth eClaims API ────────────────────────────────────────────────────
# Leave blank to use simulation mode (no real claims submitted)
# Obtain credentials from PhilHealth eClaims portal for accredited facilities
PHILHEALTH_API_URL=
PHILHEALTH_FACILITY_CODE=
PHILHEALTH_API_KEY=

# ── HMO Direct Billing APIs ───────────────────────────────────────────────────
# Leave blank to use simulation mode for any HMO
# Each HMO requires separate credentials from their provider portal

# Maxicare Healthcare (OAuth2)
MAXICARE_API_URL=
MAXICARE_FACILITY_CODE=
MAXICARE_CLIENT_ID=
MAXICARE_CLIENT_SECRET=

# PhilamLife Health (API Key)
PHILAM_API_URL=
PHILAM_FACILITY_CODE=
PHILAM_API_KEY=

# Intellicare (API Key)
INTELLICARE_API_URL=
INTELLICARE_FACILITY_CODE=
INTELLICARE_API_KEY=
