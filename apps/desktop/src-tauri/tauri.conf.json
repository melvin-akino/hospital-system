{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iHIMS",
  "version": "1.0.0",
  "identifier": "com.pibs.ihims",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5175",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "iHIMS — Integrated Hospital Information Management System",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://localhost:3001 ws://localhost:3001; font-src 'self' data:;"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "iHIMS — Hospital Information System"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/api-server"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installMode": "perMachine"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libssl3"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "publisher": "PIBS Technology",
    "copyright": "Copyright © 2025 PIBS Technology",
    "category": "HealthcareAndFitness",
    "shortDescription": "Integrated Hospital Information Management System",
    "longDescription": "iHIMS is a full-featured hospital information management system covering clinical, billing, pharmacy, laboratory, nursing, and administrative workflows."
  }
}
