{
  "$schema": "https://schema.tauri.app/security/2",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "portal"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    "shell:allow-stdin-write",
    "shell:allow-spawn",
    "notification:default",
    "dialog:default",
    "fs:default",
    "process:allow-restart",
    "process:allow-exit",
    "updater:default"
  ]
}
