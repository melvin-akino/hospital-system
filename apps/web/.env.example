# iHIMS Web App — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# API base URL (proxied via Vite in development — leave blank)
# VITE_API_URL=

# Socket.io server URL (proxied in development — leave blank)
# VITE_SOCKET_URL=
